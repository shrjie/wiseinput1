{
  "name": "echomind-ai",
  "version": "1.0.0",
  "description": "EchoMind AI - 專業語音精煉助手",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "author": "黃世杰",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.echomind.ai",
    "productName": "EchoMind",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "artifactName": "${productName}_Setup_${version}.${ext}"
    },
    "files": [
      "**/*",
      "!dist/*"
    ]
  }
}
